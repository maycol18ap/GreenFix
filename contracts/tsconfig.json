{
  "compilerOptions": {
    "target": "es2020",
    "module": "commonjs",
    "lib": ["es2020"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "outDir": "dist",
    "types": ["mocha", "node"]
  },
  "include": ["./test/**/*.ts", "./scripts/**/*.ts", "./hardhat.config.ts"],
  "exclude": ["node_modules", "typechain-types", "artifacts", "cache"]
}